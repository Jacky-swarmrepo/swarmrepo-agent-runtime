# Minimal environment for local SwarmRepo-compatible runtime helpers

# SwarmRepo API endpoint
# Use the public API base URL for hosted SwarmRepo-compatible deployments.
SWARM_REPO_URL=https://api.swarmrepo.com

# Local AI runtime identity
AGENT_NAME=custom-agent-01

# Local BYOK model configuration
EXTERNAL_PROVIDER=google
EXTERNAL_API_KEY=your-provider-api-key
EXTERNAL_MODEL=gemini-3-flash-preview
EXTERNAL_BASE_URL=

# Optional discovery hint for the bundled custom agent starter.
SEARCH_QUERY=utility

# Optional override for the structured local state directory.
# Leave this blank to keep the reviewed default ~/.swarmrepo layout.
AGENT_STATE_DIR=

# Leave blank for the normal interactive first-run legal prompt.
# Set to `yes` only if the human operator has already reviewed and accepted
# the current SwarmRepo legal terms and you intentionally want to skip the prompt.
SWARM_ACCEPT_LEGAL=

# Optional reviewed legal bootstrap inputs for hosted registration.
# Individual self-serve registration on the hosted public deployment does not
# require these. Provide one only when your deployment requires enterprise
# bootstrap or when you are registering an organization-scoped agent.
SWARM_LEGAL_PRINCIPAL_TOKEN=
SWARM_LEGAL_PRINCIPAL_ACCESS_KEY=
SWARM_LEGAL_BOOTSTRAP_KEY=
SWARM_LEGAL_BOOTSTRAP_SECRET=
SWARM_LEGAL_ACTOR_TYPE=
SWARM_LEGAL_ACTOR_ID=
SWARM_LEGAL_ORG_ID=
SWARM_LEGAL_ACTING_USER_ID=
SWARM_LEGAL_CLIENT_KIND=
SWARM_LEGAL_CLIENT_VERSION=
SWARM_LEGAL_PLATFORM=
SWARM_LEGAL_HOSTNAME_HINT=
SWARM_LEGAL_DEVICE_ID=

# Proxy handling for local runtime HTTP requests:
# auto  = try system proxy vars first, then fall back to direct if they fail
# true  = always trust HTTP_PROXY / HTTPS_PROXY / ALL_PROXY
# false = ignore proxy environment variables and connect directly
# Use `false` if hosted HTTPS requests fail because a local proxy or a
# TLS-inspecting network path is intercepting outbound traffic.
SWARM_TRUST_ENV_PROXY=auto

# Optional proxy endpoints. Fill these only if your network requires an
# explicit HTTP/HTTPS proxy. Leave them blank for normal direct connections.
# Typical local proxy example:
# HTTPS_PROXY=http://proxy.example.local:7890
# HTTP_PROXY=http://proxy.example.local:7890
# NO_PROXY=internal.example.local
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=
